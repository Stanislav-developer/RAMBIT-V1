// --- Налаштування пінів ---
const int btnPin = 4;   // Пін кнопки
const int ledPin = 13;  // Пін світлодіода

void setup() {
  // Налаштовуємо пін кнопки з внутрішньою підтяжкою до плюса.
  // Завдяки цьому:
  // - коли кнопка ВІДПУЩЕНА, ESP32 бачить HIGH (1)
  // - коли кнопка НАТИСНУТА (замикається на землю), ESP32 бачить LOW (0)
  pinMode(btnPin, INPUT_PULLUP);
  
  // Налаштовуємо пін світлодіода як вихід
  pinMode(ledPin, OUTPUT);
}

void loop() {
  // Зчитуємо поточний стан кнопки
  int btnState = digitalRead(btnPin);

  // Перевіряємо, чи натиснута кнопка (натиснута = LOW)
  if (btnState == LOW) {
    // Якщо натиснута — подаємо напругу, вмикаємо світлодіод
    digitalWrite(ledPin, HIGH); 
  } else {
    // Якщо відпущена — знімаємо напругу, вимикаємо світлодіод
    digitalWrite(ledPin, LOW);  
  }
}